# ============================================================
# SonarQube 部署环境变量（复制为 .env 后填写真实值，不要提交到仓库）
#   cp .env.example .env
# ============================================================

# ---- 版本钉死（关键）：插件版本必须与 SonarQube 主.次版本一致 ----
# 规则：插件 X.Y.Z 对应 SonarQube X.Y.x。升级时两者一起改。
# 镜像 tag 形如 <version>-community，可在 Docker Hub sonarqube 标签页确认。
SONARQUBE_TAG=26.5-community
PLUGIN_VERSION=26.5.0

# ---- RDS PostgreSQL（用内网地址）----
RDS_HOST=pgm-xxxxxxxx.pg.rds.aliyuncs.com
RDS_PORT=5432
RDS_DB=sonarqube
RDS_USER=sonar
RDS_PASSWORD=CHANGE_ME_strong_password

# ---- SonarQube 对外端口 ----
SONAR_PORT=9000
